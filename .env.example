APP_NAME=vsedetalki.ru
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://vsedetalki.ru

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vsedetali
DB_USERNAME=root
DB_PASSWORD=

# Для PHPUnit см. phpunit.xml: отдельная БД vsedetali_test на том же хосте.
# SQLite (если нужен): DB_CONNECTION=sqlite и DB_DATABASE с путём к файлу.

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Для HTTPS (Laragon .test и т.п.)
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=reverb

# Reverb: клиент (Echo) и `php artisan reverb:start` — один набор ключей/хоста/порта.
# После изменения REVERB_* или VITE_REVERB_* выполните: npm run build (или npm run dev).
REVERB_APP_ID=100001
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
# public — загрузки Filament в storage/app/public (доступны по /storage через symlink)
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Beget SMTP (исходящая): smtp.beget.com. Входящая — imap.beget.com / pop3.beget.com (для почтовых клиентов).
# Альтернатива: порт 587, MAIL_SCHEME=null и в некоторых сборках нужен MAIL_ENCRYPTION=tls — см. документацию Beget.
MAIL_MAILER=smtp
MAIL_HOST=smtp.beget.com
MAIL_PORT=465
MAIL_SCHEME=smtps
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="info@vsedetalki.ru"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# RapidAPI — Auto Parts Catalog
# https://rapidapi.com/makingdatameaningful/api/auto-parts-catalog
RAPIDAPI_AUTO_PARTS_KEY=
# RAPIDAPI_AUTO_PARTS_HOST=auto-parts-catalog.p.rapidapi.com
RAPIDAPI_AUTO_PARTS_LANG_ID=16
# Для списка авто по OEM иногда нужен другой lang_id (например 4) — см. curl в документации API.
RAPIDAPI_AUTO_PARTS_COUNTRY_FILTER_ID=63
RAPIDAPI_AUTO_PARTS_VEHICLE_TYPE_ID=1

# Импорт CSV «Остатки»: фото по URL из ответа API (s3image); выкл. = false. Имеет смысл при непустом RAPIDAPI_AUTO_PARTS_KEY.
REMAINS_IMPORT_CATALOG_IMAGES=true
REMAINS_IMPORT_CATALOG_IMAGE_SLEEP_MS=80
REMAINS_IMPORT_CATALOG_IMAGE_MAX_BYTES=6291456
REMAINS_IMPORT_DEFAULT_MODEL=Общее
# true = при импорте тянуть марку/модель из TecDoc (тяжёлый API). false = догрузка: php artisan products:sync-catalog-vehicles
REMAINS_IMPORT_SYNC_CATALOG_VEHICLES=false
# Сколько вариантов номера перебирать при поиске в каталоге (SKU, до «/», без дефисов, колонка «Код»)
REMAINS_IMPORT_CATALOG_SEARCH_CANDIDATE_LIMIT=8

# Витрина: если в БД у марка/модель нет годов — диапазон в селекте «Год» (см. config/storefront.php)
STOREFRONT_VEHICLE_YEAR_FALLBACK_WHEN_EMPTY=true
STOREFRONT_VEHICLE_YEAR_FALLBACK_FROM=1990
# Пусто = «до» текущего календарного года
STOREFRONT_VEHICLE_YEAR_FALLBACK_TO=
